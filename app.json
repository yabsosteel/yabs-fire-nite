{
  "expo": {
    "name": "yabs-fire-nite",
    "slug": "yabs-fire-nite",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/fire.png",
    "scheme": "yabsfirenite",
    "userInterfaceStyle": "automatic",

    "splash": {
      "image": "./assets/fire.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f10"
    },

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "package": "com.yabsosteel.yabsfirenite",
      "googleServicesFile": "./google-services.json",

      "adaptiveIcon": {
        "foregroundImage": "./assets/fire.png",
        "backgroundColor": "#0f0f10"
      },

      "predictiveBackGestureEnabled": false
    },

    "web": {
      "output": "static",
      "favicon": "./assets/fire.png"
    },

    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "223f7294-5fbb-4f95-886f-b5312249b67a"
      }
    }
  }
}